# LLM API 配置
# 可用提供商: openai, aliyun, baidu
LLM_PROVIDER=openai

# OpenAI 配置
# 示例: sk-xxxxx
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 阿里云通义千问配置
ALIYUN_API_KEY=your-aliyun-api-key-here
ALIYUN_MODEL=qwen-turbo

# 百度文心一言配置
BAIDU_API_KEY=your-baidu-api-key-here

# OCR 配置
# 可用提供商: openai, aliyun, baidu (默认使用 openai)
OCR_PROVIDER=openai
OPENAI_OCR_MODEL=gpt-4o
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key
BAIDU_SECRET_KEY=your-baidu-secret-key-here

# 其他配置
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=360